## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Auto-generated files
*.Generated.cs
*.g.cs
*.g.i.cs

# Build results
bin/
obj/
Debug/
Release/
x64/
x86/

# Visual Studio Code settings
.vscode/

# NuGet Packages
*.nupkg
packages/
# NuGet v3
*.nuget.props
*.nuget.targets

# Dotnet CLI files
project.lock.json
project.fragment.lock.json
artifacts/

# Rider IDE files
.idea/

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper

# OS generated files
.DS_Store
Thumbs.db

# Logs
*.log

# Dotnet test results
TestResults/
*.trx
coverage/

# Dotnet publish folder
publish/